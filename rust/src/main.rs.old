use nalgebra::{DMatrix, DVector, SymmetricEigen};
use num_complex::Complex64;
use rayon::prelude::*;
use std::f64::consts::PI;
use std::fs;
use std::path::PathBuf;
use std::time::Instant;

// =====================================================================
// Configuration
// =====================================================================
const MAX_PRIME: usize = 1_000_000; // sieve up to 1 million — gives ~78,498 primes
const DATA_DIR: &str = "~/rh_data";

fn expand_home(path: &str) -> PathBuf {
    if path.starts_with("~/") {
        if let Some(home) = std::env::var_os("HOME") {
            return PathBuf::from(home).join(&path[2..]);
        }
    }
    PathBuf::from(path)
}

// =====================================================================
// Prime sieve
// =====================================================================
fn sieve_primes(max: usize) -> Vec<usize> {
    let t = Instant::now();
    let sieve = primal::Sieve::new(max);
    let primes: Vec<usize> = sieve.primes_from(2).collect();
    println!(
        "  Sieved {} primes up to {} in {:.1}ms",
        primes.len(),
        max,
        t.elapsed().as_secs_f64() * 1000.0
    );
    primes
}

// =====================================================================
// Load zeros from CSV
// =====================================================================
fn load_zeros(filename: &str) -> Vec<f64> {
    let path = expand_home(DATA_DIR).join(filename);
    let content = fs::read_to_string(&path)
        .unwrap_or_else(|e| panic!("Cannot read {}: {}", path.display(), e));
    content
        .lines()
        .filter(|l| !l.trim().is_empty())
        .map(|l| l.trim().parse::<f64>().expect("Invalid number in zeros file"))
        .collect()
}

// =====================================================================
// Build Xi-weighted Gram matrix (parallel over primes)
// =====================================================================
fn build_gram_xi(
    n_zeros: usize,
    zeros: &[f64],
    primes: &[usize],
    log_primes: &[f64],
    sigma: f64,
    n_primes: usize,
    normalize: bool,
) -> DMatrix<f64> {
    let n = n_zeros.min(zeros.len());
    let np = n_primes.min(primes.len());

    // Each prime contributes w * outer(phases, conj(phases))
    // Sum in parallel using rayon
    let partial_matrices: Vec<DMatrix<f64>> = (0..np)
        .into_par_iter()
        .map(|pi| {
            let p = primes[pi] as f64;
            let logp = log_primes[pi];
            let w = logp * ((sigma - 0.5) * logp).cosh() / p.sqrt();

            // Compute phases
            let phases: Vec<Complex64> = (0..n)
                .map(|i| Complex64::new(0.0, -zeros[i] * logp).exp())
                .collect();

            // Build outer product (real part only, since G is Hermitian)
            let mut g = DMatrix::<f64>::zeros(n, n);
            for i in 0..n {
                for j in i..n {
                    let val = w * (phases[i] * phases[j].conj()).re;
                    g[(i, j)] = val;
                    g[(j, i)] = val;
                }
            }
            g
        })
        .collect();

    // Sum all partial matrices
    let mut gram = DMatrix::<f64>::zeros(n, n);
    for g in partial_matrices {
        gram += g;
    }

    if normalize {
        let tr = gram.trace();
        if tr > 1e-15 {
            gram *= n as f64 / tr;
        }
    }

    gram
}

// =====================================================================
// Eigenvalue analysis
// =====================================================================
struct GramStats {
    cond: f64,
    lambda_min: f64,
    lambda_max: f64,
}

fn gram_stats(gram: &DMatrix<f64>) -> GramStats {
    let eigen = SymmetricEigen::new(gram.clone());
    let eigvals = eigen.eigenvalues;
    let min = eigvals.min();
    let max = eigvals.max();
    let cond = if min.abs() > 1e-15 { max / min } else { f64::INFINITY };
    GramStats {
        cond,
        lambda_min: min,
        lambda_max: max,
    }
}

// =====================================================================
// TEST A: σ-dependence for a given set of zeros
// =====================================================================
fn test_sigma_dependence(
    label: &str,
    zeros: &[f64],
    primes: &[usize],
    log_primes: &[f64],
    n_zeros: usize,
    n_primes: usize,
    n_sigma: usize,
) {
    let n = n_zeros.min(zeros.len());
    println!("\n  --- {} (N={}, P={}) ---", label, n, n_primes);

    let sigmas: Vec<f64> = (0..n_sigma)
        .map(|i| 0.05 + 0.9 * (i as f64) / ((n_sigma - 1) as f64))
        .collect();

    let results: Vec<(f64, f64, f64, f64)> = sigmas
        .par_iter()
        .map(|&sigma| {
            let g = build_gram_xi(n, zeros, primes, log_primes, sigma, n_primes, true);
            let s = gram_stats(&g);
            (sigma, s.cond, s.lambda_min, s.lambda_max)
        })
        .collect();

    // Find minimum condition number
    let mut min_cond = f64::INFINITY;
    let mut min_sigma = 0.5;
    let mut cond_at_half = 0.0;

    for &(sigma, cond, _, _) in &results {
        if cond < min_cond {
            min_cond = cond;
            min_sigma = sigma;
        }
        if (sigma - 0.5).abs() < 0.01 {
            cond_at_half = cond;
        }
    }

    println!("    Min condition: {:.4} at σ={:.3}", min_cond, min_sigma);
    println!("    Cond at σ=0.5: {:.4}", cond_at_half);
    if (min_sigma - 0.5).abs() < 0.03 {
        println!("    >>> σ=1/2 IS the minimum <<<");
    } else {
        println!("    >>> Minimum at σ={:.3} <<<", min_sigma);
    }

    // Print selected values
    for &(sigma, cond, lmin, lmax) in &results {
        if [0.1, 0.2, 0.3, 0.4, 0.45, 0.48, 0.5, 0.52, 0.55, 0.6, 0.7, 0.8, 0.9]
            .iter()
            .any(|&s| (sigma - s).abs() < 0.012)
        {
            println!(
                "      σ={:.3}: cond={:.4}  λ_min={:.6}  λ_max={:.6}",
                sigma, cond, lmin, lmax
            );
        }
    }
}

// =====================================================================
// TEST B: Scaling law
// =====================================================================
fn test_scaling(
    zeros: &[f64],
    primes: &[usize],
    log_primes: &[f64],
    prime_ratio: usize,
) {
    let sizes: Vec<usize> = vec![
        10, 20, 30, 50, 75, 100, 150, 200, 300, 400, 500, 700, 1000, 1500, 2000,
    ];

    println!("\n  Prime ratio: {} primes per zero (minimum 500)", prime_ratio);

    for &n in &sizes {
        if n > zeros.len() {
            break;
        }
        let np = (prime_ratio * n).max(500).min(primes.len());
        let t = Instant::now();
        let g = build_gram_xi(n, zeros, primes, log_primes, 0.5, np, true);
        let s = gram_stats(&g);
        let elapsed = t.elapsed().as_secs_f64();
        println!(
            "    N={:5}, P={:6}: cond={:10.3}  λ_min={:.8}  λ_max={:.6}  ({:.2}s)",
            n, np, s.cond, s.lambda_min, s.lambda_max, elapsed
        );
    }
}

// =====================================================================
// TEST C: Prime ratio sweep
// =====================================================================
fn test_prime_ratio(
    zeros: &[f64],
    primes: &[usize],
    log_primes: &[f64],
    n_zeros: usize,
) {
    let ratios = [1, 2, 3, 5, 8, 10, 15, 20, 30, 50, 75, 100, 150, 200];

    println!("\n  Fixed N={}, varying prime ratio:", n_zeros);

    for &r in &ratios {
        let np = (r * n_zeros).min(primes.len());
        if np == (ratios[ratios.len() - 1] * n_zeros).min(primes.len()) && r != ratios[ratios.len() - 1] {
            // Skip if we've maxed out primes (would duplicate)
            if r > 1 && np == ((r - 1) * n_zeros).min(primes.len()) {
                continue;
            }
        }
        let g = build_gram_xi(n_zeros, zeros, primes, log_primes, 0.5, np, true);
        let s = gram_stats(&g);
        println!(
            "    ratio={:4} ({:6} primes): cond={:.4}  λ_min={:.6}",
            r, np, s.cond, s.lambda_min
        );
    }
}

// =====================================================================
// MAIN
// =====================================================================
fn main() {
    println!("╔══════════════════════════════════════════════════════════════╗");
    println!("║     RIEMANN HYPOTHESIS: CRYSTAL ANALYSIS (Rust Edition)    ║");
    println!("╚══════════════════════════════════════════════════════════════╝");
    println!();

    let total_time = Instant::now();

    // Step 1: Sieve primes
    println!("Step 1: Generating primes...");
    let primes = sieve_primes(MAX_PRIME);
    let log_primes: Vec<f64> = primes.iter().map(|&p| (p as f64).ln()).collect();
    println!("  {} primes available", primes.len());

    // Step 2: Load zeros
    println!("\nStep 2: Loading precomputed zeros...");

    let zeta_zeros = load_zeros("zeta_zeros.csv");
    println!("  Loaded {} Riemann zeta zeros", zeta_zeros.len());

    let dirichlet_files = [
        ("chi_mod3_zeros.csv", "χ mod 3"),
        ("chi_mod4_zeros.csv", "χ mod 4"),
        ("chi_mod5_zeros.csv", "χ mod 5"),
        ("chi_mod7_zeros.csv", "χ mod 7"),
        ("chi_mod8_zeros.csv", "χ mod 8"),
        ("chi_mod11_zeros.csv", "χ mod 11"),
        ("chi_mod13_zeros.csv", "χ mod 13"),
    ];

    let mut dirichlet_zeros: Vec<(String, Vec<f64>)> = Vec::new();
    for (file, label) in &dirichlet_files {
        let path = expand_home(DATA_DIR).join(file);
        if path.exists() {
            let zeros = load_zeros(file);
            println!("  Loaded {} zeros for {}", zeros.len(), label);
            dirichlet_zeros.push((label.to_string(), zeros));
        }
    }

    // ==================================================================
    println!("\n{}", "=".repeat(66));
    println!("TEST A: UNIVERSALITY — σ-DEPENDENCE");
    println!("{}", "=".repeat(66));

    // Riemann zeta
    test_sigma_dependence(
        "Riemann ζ",
        &zeta_zeros,
        &primes,
        &log_primes,
        30,
        5000,
        60,
    );

    // Dirichlet L-functions
    for (label, zeros) in &dirichlet_zeros {
        let n = zeros.len().min(20);
        test_sigma_dependence(label, zeros, &primes, &log_primes, n, 3000, 40);
    }

    // ==================================================================
    println!("\n{}", "=".repeat(66));
    println!("TEST B: SCALING LAW");
    println!("{}", "=".repeat(66));

    // With fixed high prime ratio
    println!("\n  --- Ratio = 20 (scaled primes) ---");
    test_scaling(&zeta_zeros, &primes, &log_primes, 20);

    println!("\n  --- Ratio = 50 (more primes) ---");
    test_scaling(&zeta_zeros, &primes, &log_primes, 50);

    println!("\n  --- Ratio = 100 (maximum primes) ---");
    test_scaling(&zeta_zeros, &primes, &log_primes, 100);

    // ==================================================================
    println!("\n{}", "=".repeat(66));
    println!("TEST C: PRIME RATIO EFFECT");
    println!("{}", "=".repeat(66));

    for &n in &[50, 100, 200, 500] {
        if n <= zeta_zeros.len() {
            test_prime_ratio(&zeta_zeros, &primes, &log_primes, n);
        }
    }

    // ==================================================================
    println!("\n{}", "=".repeat(66));
    println!("TEST D: LARGE-SCALE σ-DEPENDENCE");
    println!("{}", "=".repeat(66));
    println!("Testing with larger N and more primes...");

    for &n in &[50, 100, 200] {
        if n <= zeta_zeros.len() {
            test_sigma_dependence(
                &format!("ζ (N={})", n),
                &zeta_zeros,
                &primes,
                &log_primes,
                n,
                10000,
                40,
            );
        }
    }

    // ==================================================================
    println!("\n{}", "=".repeat(66));
    println!("DONE");
    println!("{}", "=".repeat(66));
    println!(
        "Total time: {:.1}s",
        total_time.elapsed().as_secs_f64()
    );
}
